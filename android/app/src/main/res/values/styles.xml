<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- خلفية اللحظة الأولى: صورة العلامة التجارية نفسها (نفس تصميم شاشة الفتح)
             بدون أي أيقونة منفصلة فوقها -->
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>

        <!-- أيقونة شفافة تمامًا عشان نظام أندرويد ما يعرضش حرف الـ M الافتراضي -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_blank</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimationDuration">1</item>

        <!-- بعد إطار splash النظام الإجباري، سلّم فورًا لثيم التطبيق العادي
             عشان شاشة التحميل المتحركة بتاعتنا (AnimatedSplash) تظهر على طول -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>

        <!-- ده اللي بيظهر فعليًا كخلفية طول مدة الـ splash الأصلي بتاع Capacitor
             (اللي بيتحكم فيه launchShowDuration) — صورة العلامة التجارية كاملة -->
        <item name="android:background">@drawable/splash</item>
        <item name="android:windowBackground">@drawable/splash</item>
    </style>
</resources>